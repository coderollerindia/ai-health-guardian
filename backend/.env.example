# Gemini API key from Google AI Studio (https://aistudio.google.com/apikey)
GEMINI_API_KEY=your-gemini-api-key-here

# Supabase project URL, e.g. https://xxxxxxxx.supabase.co
SUPABASE_URL=https://your-project-ref.supabase.co

# Supabase service role key (Project Settings > API) - server-side only, bypasses RLS, NEVER expose to frontend
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# OPTIONAL. Legacy shared HS256 JWT secret (Project Settings > API > JWT Keys > Legacy JWT Secret).
# Only needed as a fallback for old HS256-signed tokens right after a project migrates to the newer
# asymmetric (ES256) signing keys — new tokens are verified automatically via the project's JWKS
# endpoint instead, no secret required. Leave blank on projects that only ever used ES256.
SUPABASE_JWT_SECRET=

# Extra CORS origin to allow in addition to http://localhost:5173 (e.g. your deployed Vercel URL)
ALLOWED_ORIGIN=https://your-app.vercel.app

# Environment name, e.g. development | production
ENV=development
